---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Astro Starwind Blank Starter">
  <script is:inline slot="head">
    const prefs = navigator.languages || [navigator.language];
    if (prefs.some((l) => l.startsWith("en"))) {
      window.location.replace("/en" + window.location.search);
    }
  </script>
  <main class="min-h-screen bg-background flex flex-col items-center justify-center p-4">
    <div class="max-w-3xl w-full rounded-2xl p-8 text-center space-y-6">
      <h1 class="font-display text-4xl font-bold tracking-tight">
        Astro + Starwind <span class="text-primary">Blank Starter</span>
      </h1>
      
      <p class="text-muted-foreground text-lg text-center max-w-2xl mx-auto">
        Your new blank canvas. Build something amazing. (Root locale fallback)
      </p>

      <div class="mt-8 pt-6 border-t border-border flex justify-center gap-4 text-sm text-foreground">
        <a href="/" class="hover:underline hover:text-primary transition-colors">DE</a>
        <a href="/en" class="hover:underline hover:text-primary transition-colors">EN</a>
      </div>
    </div>
  </main>
</Layout>
